# Copy this file to .env and fill in the values for local development.

NODE_ENV=development
LOG_LEVEL=debug

# JSON persistence directory (default: ~/.mcp-management on the current user). Optional override.
# Audit logs go to {MCP_DATA_DIR}/logs/plugin-audit.log (Winston), not store.json.
# MCP_DATA_DIR=F:/data/mcp-management

# Use in-memory persistence only (e.g. forced tests). Normally unset so JSON file store is used.
# MCP_IN_MEMORY_PERSISTENCE=true

# MCP stdio server does not listen on this port today; reserved for future HTTP/SSE.
PORT=3000

# Environment variables are loaded from a `.env` file in the current working directory (see `import "dotenv/config"` in apps/server/src/config).

# Allow path / package / bundle plugin loaders (default: built-ins only).
# MCP_ALLOW_EXTERNAL_PLUGINS=true
